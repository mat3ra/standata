{
  "extends": ["@exabyte-io/eslint-config"],
  "ignorePatterns": ["dist/"],
  "settings": {
    "import/resolver": {
      "node": { "extensions": [".js", ".jsx", ".ts", ".tsx"] }
    }
  },
  "overrides": [
    {
      "files": ["scripts/**/*.ts", "scripts/**/*.js"],
      "rules": {
        "import/no-extraneous-dependencies": ["error", { "devDependencies": true }]
      }
    }
  ]
}

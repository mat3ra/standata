        },
        {
            "name": "assign-elemental-energy-sum",
            "type": "assignment",
            "operand": "E_ELEMENTAL_SUM",
            "value": "sum(ELEMENTAL_TE_USED_BY_SYMBOL[e['value']]['total_energy_per_atom'] for e in MATERIAL.basis.elements)",
            "input": [],
            "results": [],
            "monitors": [],
            "preProcessors": [],
            "postProcessors": [],
            "status": "idle",
            "statusTrack": [],
            "tags": [],
            "flowchartId": "assign-elemental-energy-sum",
            "head": false,

            "type": "assignment",
            "operand": "ELEMENTAL_TE_USED_BY_SYMBOL",
            "value": "{el: {'formula': el, 'n_atoms': len(ELEMENT_MATERIALS[el].basis.elements), 'is_elemental': True, 'total_energy': ELEMENTAL_TE_HOLDER_BY_SYMBOL[el].data.value, 'total_energy_per_atom': ELEMENTAL_TE_HOLDER_BY_SYMBOL[el].data.value / len(ELEMENT_MATERIALS[el].basis.elements), 'precision_value': ELEMENTAL_TE_HOLDER_BY_SYMBOL[el].precision.value, 'precision_metric': ELEMENTAL_TE_HOLDER_BY_SYMBOL[el].precision.metric} for el in ELEMENTS if ELEMENTAL_TE_HOLDER_BY_SYMBOL[el]}",
            "input": [],
            "results": [],
            "monitors": [],
            "preProcessors": [],
            "postProcessors": [],
            "status": "idle",
            "statusTrack": [],
            "tags": [],
            "flowchartId": "assign-elemental-te-used-by-symbol",
